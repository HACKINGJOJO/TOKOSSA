# ===========================================
# TOKOSSA - Variables d'environnement
# ===========================================

# Base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/tokossa?schema=public"

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-min-32-chars

# KKiaPay (Paiement Mobile Money)
KKIAPAY_PUBLIC_KEY=pk_xxxxxxxxxxxxxxxx
KKIAPAY_PRIVATE_KEY=sk_xxxxxxxxxxxxxxxx

# WhatsApp Business Cloud API (Meta)
# 1. Creer un compte sur https://business.facebook.com
# 2. Aller sur https://developers.facebook.com → WhatsApp → Getting Started
# 3. Recuperer le token et le Phone Number ID
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# WhatsApp Business (numero public affiche aux clients)
NEXT_PUBLIC_WHATSAPP_BUSINESS=22990000000
ADMIN_WHATSAPP_NUMBER=22990000000

# Resend (Email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@tokossa.bj

# Cloudinary (Images)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxx

# Admin
ADMIN_EMAIL=admin@tokossa.bj
ADMIN_PASSWORD=your-secure-admin-password

# Analytics
NEXT_PUBLIC_FB_PIXEL_ID=xxxxxxxxxxxxxxxx
